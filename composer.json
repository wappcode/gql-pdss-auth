{
  "name": "wappcode/gql-pdss-auth",
  "version": "4.0.9",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "GPDAuth\\": "GPDAuth/src",
      "GPDAuthJWT\\": "GPDAuthJWT/src"
    }
  },
  "require-dev": {
    "wappcode/gqlpdss": "dev-master",
    "phpunit/phpunit": "^9.6",
    "wappcode/graphql-basic-client": "^1.0"
  },
  "autoload-dev": {
    "psr-4": {
      "AppModule\\": "dev/modules/AppModule/src/"
    }
  },
  "require": {
    "php": ">=8.2",
    "firebase/php-jwt": "^7.0",
    "guzzlehttp/guzzle": "^7.8",
    "psr/http-message": "^2.0",
    "psr/http-server-middleware": "^1.0",
    "wappcode/pdss-utilities": "^4.0.0"
