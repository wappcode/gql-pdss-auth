{
    "realm": "gpdauth",
    "displayName": "GPD Auth Realm",
    "enabled": true,
    "sslRequired": "external",
    "registrationAllowed": false,
    "loginWithEmailAllowed": true,
    "duplicateEmailsAllowed": false,
    "resetPasswordAllowed": true,
    "editUsernameAllowed": false,
    "bruteForceProtected": true,
    "accessTokenLifespan": 1800,
    "ssoSessionIdleTimeout": 1800,
    "ssoSessionMaxLifespan": 36000,
    "users": [
        {
            "username": "appuser",
            "email": "appuser@example.com",
            "firstName": "App",
            "lastName": "User",
            "enabled": true,
            "emailVerified": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "appuser123",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "default-roles-gpdauth",
                "app-user"
            ]
        }
    ],
    "roles": {
        "realm": [
            {
                "name": "app-user",
                "description": "Standard application user"
            },
            {
                "name": "app-admin",
                "description": "Application administrator"
            }
        ],
        "client": {
            "php-backend-client": [
                {
                    "name": "backend-service",
                    "description": "Role assigned to the PHP backend service account"
                }
            ]
        }
    },
    "clients": [
        {
            "clientId": "php-backend-client",
            "name": "PHP Backend M2M Client",
            "description": "Machine-to-machine client for PHP backend (client credentials grant)",
            "enabled": true,
            "protocol": "openid-connect",
            "publicClient": false,
            "clientAuthenticatorType": "client-secret",
            "secret": "php-backend-secret-change-me",
            "standardFlowEnabled": false,
            "implicitFlowEnabled": false,
            "directAccessGrantsEnabled": false,
            "serviceAccountsEnabled": true,
            "authorizationServicesEnabled": false,
            "fullScopeAllowed": true,
            "attributes": {
                "access.token.lifespan": "1800",
                "use.refresh.tokens": "false"
            },
            "defaultClientScopes": [
                "web-origins",
                "profile",
                "roles",
                "email"
            ],
            "optionalClientScopes": [],
            "protocolMappers": [
                {
                    "name": "php-backend-subject",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-property-mapper",
                    "consentRequired": false,
                    "config": {
                        "user.attribute": "id",
                        "claim.name": "sub",
                        "jsonType.label": "String",
                        "id.token.claim": "true",
                        "access.token.claim": "true",
                        "userinfo.token.claim": "true"
                    }
                },
                {
                    "name": "php-backend-audience",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-audience-mapper",
                    "consentRequired": false,
                    "config": {
                        "included.client.audience": "php-backend-client",
                        "id.token.claim": "false",
                        "access.token.claim": "true"
                    }
                }
            ]
        },
        {
            "clientId": "angular-frontend-client",
            "name": "Angular Frontend Client",
            "description": "Public PKCE client for Angular SPA frontend",
            "enabled": true,
            "protocol": "openid-connect",
            "publicClient": true,
            "standardFlowEnabled": true,
            "implicitFlowEnabled": false,
            "directAccessGrantsEnabled": true,
            "serviceAccountsEnabled": false,
            "fullScopeAllowed": true,
            "redirectUris": [
                "http://localhost:4200/*",
                "http://localhost:4200"
            ],
            "webOrigins": [
                "http://localhost:4200"
            ],
            "attributes": {
                "pkce.code.challenge.method": "S256",
                "post.logout.redirect.uris": "http://localhost:4200/*"
            },
            "defaultClientScopes": [
                "web-origins",
                "profile",
                "roles",
                "email"
            ],
            "optionalClientScopes": [
                "address",
                "phone",
                "offline_access"
            ],
            "protocolMappers": [
                {
                    "name": "angular-frontend-subject",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-usermodel-property-mapper",
                    "consentRequired": false,
                    "config": {
                        "user.attribute": "id",
                        "claim.name": "sub",
                        "jsonType.label": "String",
                        "id.token.claim": "true",
                        "access.token.claim": "true",
                        "userinfo.token.claim": "true"
                    }
                },
                {
                    "name": "angular-frontend-audience",
                    "protocol": "openid-connect",
                    "protocolMapper": "oidc-audience-mapper",
                    "consentRequired": false,
                    "config": {
                        "included.client.audience": "angular-frontend-client",
                        "id.token.claim": "false",
                        "access.token.claim": "true"
                    }
                }
            ]
        }
    ],
    "scopeMappings": [
        {
            "client": "php-backend-client",
            "roles": [
                "app-admin",
                "app-user"
            ]
        }
    ],
    "clientScopeMappings": {
        "php-backend-client": [
            {
                "client": "php-backend-client",
                "roles": [
                    "backend-service"
                ]
            }
        ]
    }
}